# RLdC AiNalyzator — przykładowa konfiguracja (BEZ sekretów)
#
# Skopiuj do `.env` i uzupełnij własnymi danymi.

# --- OpenAI (WYMAGANE) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5-mini
# Backoff po błędach (sekundy) — żeby nie spamować zapytań i logów
OPENAI_BACKOFF_SECONDS=600
# Cache dla /api/account/openai-status (sekundy)
OPENAI_STATUS_CACHE_SECONDS=120

# --- Provider AI (darmowy fallback) ---
# openai  = tylko OpenAI (brak klucza/błąd = brak nowych zakresów)
# heuristic/offline = darmowe zakresy z ATR/Bollinger (bez LLM)
# auto    = OpenAI jeśli działa, inaczej heuristic
AI_PROVIDER=auto

# --- Binance (WYMAGANE do portfela/watchlisty) ---
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here
# Quote waluty do budowania par z portfela (np. WLFI + EUR => WLFIEUR)
PORTFOLIO_QUOTES=EUR,USDC

# --- Telegram (opcjonalne, ale potrzebne do potwierdzeń) ---
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
# Wysyłaj tylko krytyczne alerty (false = także potwierdzenia pending)
TELEGRAM_ERROR_ONLY=false
# Auto-push z analizy OpenAI (domyślnie OFF — raporty lepiej na żądanie)
TELEGRAM_AUTO_INSIGHTS=false

# --- Baza danych ---
DATABASE_URL=sqlite:///./trading_bot.db

# --- Backend ---
API_HOST=0.0.0.0
API_PORT=8000
# Hot-reload (dev only). Produkcyjnie zostaw false albo użyj `python -m backend.app --no-reload`.
API_RELOAD=false

# Opcjonalny token admina. Jeśli ustawiony, endpointy typu reset/control/confirm wymagają nagłówka:
# X-Admin-Token: <ADMIN_TOKEN>
ADMIN_TOKEN=

# --- Kolektor danych ---
COLLECTION_INTERVAL_SECONDS=60
WATCHLIST_REFRESH_SECONDS=900
KLINE_TIMEFRAMES=1m,1h
WS_ENABLED=true

# --- Tryb tradingu (DEMO domyślnie) ---
TRADING_MODE=demo
DEMO_TRADING_ENABLED=true
DEMO_INITIAL_BALANCE=10000
# DEMO: licz KPI i handluj tylko na symbolach z tym quote (np. EUR lub USDC).
# Jeśli puste: bierze pierwszą walutę z PORTFOLIO_QUOTES.
DEMO_QUOTE_CCY=

# Co ile zapisywać snapshoty equity do wykresów (sekundy)
ACCOUNT_SNAPSHOT_INTERVAL_SECONDS=60

# Cache dla obliczeń stanu konta (sekundy)
ACCOUNT_STATE_CACHE_SECONDS=5

# --- Risk / ochrona ---
MAX_DAILY_LOSS_PERCENT=5.0
MAX_DRAWDOWN_PERCENT=10.0

# --- DEMO: anty-spam i bezpieczeństwo ---
# Minimalny odstęp pomiędzy kolejnymi pending order dla symbolu (sekundy)
PENDING_ORDER_COOLDOWN_SECONDS=3600
# Maksymalny wiek analiz OpenAI, po którym DEMO nie generuje decyzji (sekundy)
MAX_AI_INSIGHTS_AGE_SECONDS=7200

# --- Maksymalna pewność (bardzo rzadkie sygnały) ---
# Jeśli true: podnosi progi confidence, wymaga rating 5/5, wydłuża cooldown i ogranicza liczbę transakcji.
MAX_CERTAINTY_MODE=false

# --- Uczenie (kalibracja) ---
LEARNING_DAYS=180
