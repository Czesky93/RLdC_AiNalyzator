# =============================================================================
# RLdC AiNalyzator — szablon konfiguracji
# Skopiuj do .env i uzupełnij prawdziwymi wartościami.
# NIE commituj pliku .env do repozytorium.
# =============================================================================

# --- Binance ---
BINANCE_API_KEY=YOUR_BINANCE_API_KEY
BINANCE_API_SECRET=YOUR_BINANCE_API_SECRET

# --- Telegram bot ---
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# --- Admin ---
# Klucz chroniący wrażliwe endpointy API (env, terminal, command brain).
# Jeśli puste — brak autoryzacji (tylko do środowisk lokalnych).
ADMIN_TOKEN=

# --- Baza danych ---
# Domyślnie SQLite; można podać URL PostgreSQL/MySQL.
DATABASE_URL=sqlite:///./trading_bot.db

# --- Backend ---
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
LOG_LEVEL=INFO
LOG_FILE=

# --- Tryb handlu ---
# live | demo
TRADING_MODE=demo
ALLOW_LIVE_TRADING=false

# --- Quote Currency Routing ---
# EUR | USDC | BOTH
QUOTE_CURRENCY_MODE=BOTH
# EUR | USDC (preferencja przy BOTH oraz NL: "kup btc")
PRIMARY_QUOTE=USDC
ALLOW_AUTO_CONVERT_EUR_TO_USDC=false
MIN_EUR_RESERVE=10
MIN_USDC_RESERVE=10
MIN_CONVERSION_NOTIONAL=20
CONVERSION_COOLDOWN_MINUTES=60
TARGET_USDC_BUFFER=50
MAX_CONVERSION_PER_HOUR=2

# --- Security output ---
SAFE_MODE_CONFIG_OUTPUT=true
ADMIN_ONLY_COMMANDS=true

# --- Watchlista (rozdzielona przecinkami) ---
WATCHLIST=BTCEUR,ETHEUR,SOLUSDC,XRPEUR

# --- Risk Management ---
MAX_DAILY_LOSS_PERCENT=2.0
MAX_DRAWDOWN_PERCENT=5.0

# --- Kolektor danych ---
COLLECTION_INTERVAL_SECONDS=60
KLINE_TIMEFRAMES=1h,4h,1d
WS_ENABLED=false

# --- Demo trading ---
DEMO_TRADING_ENABLED=true
DEMO_ORDER_QTY=10
DEMO_COOLDOWN_SECONDS=300
DEMO_MAX_TRADES_PER_DAY=10
DEMO_MIN_SIGNAL_CONFIDENCE=0.6
DEMO_MAX_SIGNAL_AGE_SECONDS=120
DEMO_MIN_KLINES=50
DEMO_RISK_PER_TRADE=0.01
DEMO_MAX_POSITION_QTY=5
DEMO_MIN_POSITION_QTY=1
DEMO_INITIAL_BALANCE=1000.0
DEMO_INITIAL_EQUITY=1000.0

# --- Crash protection ---
CRASH_WINDOW_MINUTES=15
CRASH_DROP_PERCENT=3.0
CRASH_COOLDOWN_SECONDS=600
CRASH_MIN_CONFIDENCE=0.7

# --- ATR stop/take profit ---
ATR_STOP_MULT=1.5
ATR_TAKE_MULT=2.5

# --- Pending orders ---
PENDING_ORDER_COOLDOWN_SECONDS=60

# --- AI / LLM ---
# Dostawca: auto | local | groq | gemini | openai | heuristic
# Zalecane: auto (next.free-first, fallback chain)
AI_PROVIDER=auto
AI_BACKOFF_SECONDS=30
MAX_CERTAINTY_MODE=false

# OpenAI (opcjonalne, płatne)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BACKOFF_SECONDS=60

# Google Gemini (darmowy tier dostępny)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq (darmowy tier dostępny, bardzo szybki)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (lokalne LLM, wymaga uruchomionego ollama serve)
OLLAMA_MODEL=qwen2.5:0.5b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TIMEOUT_SECONDS=30

# --- Zewnętrzne API (opcjonalne) ---
DRUPAL_API_URL=
DRUPAL_API_TOKEN=
NEWS_API_KEY=

# --- Frontend / publiczny dostęp ---
PUBLIC_BASE_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:8000
PUBLIC_MODE=local
FRONTEND_PORT=3000
CORS_ALLOWED_ORIGINS=http://localhost:3000

# --- Cloudflare / ngrok (opcjonalnie do ekspozycji publicznej) ---
CLOUDFLARE_TUNNEL_URL=
NGROK_URL=
